{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/image-upload/(.*)",
      "destination": "https://image.harrio.xyz/$1"
    },
    {
      "source": "/((?!.*\\.(xml|txt|png|svg|ico|js|css|woff2?|ttf|json|webmanifest)).*)",
      "destination": "/index.html"
    }
  ]
}
